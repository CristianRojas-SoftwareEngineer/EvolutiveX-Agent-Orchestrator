{
  "name": "smart-code-proxy",
  "version": "1.0.0",
  "description": "Proxy de observabilidad de alto rendimiento para interceptar, auditar y analizar el tráfico entre Claude Code (CLI oficial de Anthropic) y la API de Anthropic.",
  "main": "dist/index.js",
  "scripts": {
    "help": "tsx scripting/help.ts",
    "dev": "node --env-file-if-exists=configs/.env --import tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run clean:dist && concurrently \"npm run build:js\" \"npm run build:types\"",
    "build:js": "tsup src/index.ts --format esm --tsconfig configs/tsconfig.json --external @anthropic-ai/sdk --external @fastify/http-proxy --external fastify --external pino --external pino-pretty",
    "build:types": "tsc -p configs/tsconfig.json --emitDeclarationOnly --outDir dist",
    "format": "prettier --config configs/.prettierrc --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripting/**/*.ts\" \"docs/**/*.md\" \"*.md\" \"configs/*.json\" \"configs/*.ts\" \"*.json\"",
    "lint": "eslint --config configs/eslint.config.mjs \"src/**/*.ts\" \"tests/**/*.ts\" \"scripting/**/*.ts\"",
    "lint:fix": "eslint --config configs/eslint.config.mjs \"src/**/*.ts\" \"tests/**/*.ts\" \"scripting/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json",
    "test": "concurrently \"npm run lint\" \"npm run typecheck\" && npm run test:unit && npm run build",
    "test:quick": "concurrently \"npm run lint\" \"npm run typecheck\" && npm run test:unit",
    "test:unit": "vitest run --config configs/vitest.config.ts",
    "test:integration": "vitest run --config configs/vitest.config.ts",
    "test:watch": "vitest --config configs/vitest.config.ts",
    "test:headless-tts": "tsx scripting/headless-tts-gateway-test.ts",
    "clean:all": "concurrently \"npm run clean:dist\" \"npm run clean:modules\" \"npm run clean:sessions\" \"npm run clean:logs\"",
    "clean:dist": "rimraf dist",
    "clean:modules": "tsx scripting/clean-modules.ts",
    "clean:sessions": "rimraf sessions",
    "clean:logs": "rimraf server",
    "configure:provider": "tsx scripting/configure-provider.ts",
    "setup:install": "tsx scripting/setup.ts",
    "setup:uninstall": "tsx scripting/setup.ts --uninstall",
    "notifications:register": "tsx src/2-services/notifications/register.ts",
    "create:agents-reference": "tsx scripting/create-agents-reference.ts",
    "verify:package-scripts": "tsx scripting/verify-package-scripts.ts",
    "sessions:list": "tsx scripting/session-manager/cli.ts list",
    "sessions:archive": "tsx scripting/session-manager/cli.ts archive",
    "sessions:delete": "tsx scripting/session-manager/cli.ts delete",
    "sessions:list-archived": "tsx scripting/session-manager/cli.ts list-archived",
    "sessions:restore": "tsx scripting/session-manager/cli.ts restore",
    "sessions:sanitize:scan": "tsx scripting/session-manager/cli.ts sanitize scan",
    "sessions:sanitize": "tsx scripting/session-manager/cli.ts sanitize",
    "sessions:sanitize:all": "tsx scripting/session-manager/cli.ts sanitize all",
    "statusline:router-details:on": "tsx scripting/statusline-router-details.ts on",
    "statusline:router-details:off": "tsx scripting/statusline-router-details.ts off",
    "statusline:router-details:toggle": "tsx scripting/statusline-router-details.ts toggle"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@fastify/http-proxy": "^11.4.4",
    "commander": "^13.1.0",
    "fastify": "^5.8.5",
    "node-notifier": "^10.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fission-ai/openspec": "^1.3.1",
    "@types/node": "^25.6.0",
    "@types/node-notifier": "^8.0.5",
    "chalk": "^5.4.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
