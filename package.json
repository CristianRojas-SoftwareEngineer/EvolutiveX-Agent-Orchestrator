{
  "name": "smart-code-proxy",
  "version": "1.0.0",
  "description": "Proxy de observabilidad de alto rendimiento para interceptar, auditar y analizar el tráfico entre Claude Code (CLI oficial de Anthropic) y la API de Anthropic.",
  "main": "dist/index.js",
  "scripts": {
    "help": "tsx scripting/src/help.ts",
    "dev": "node --env-file-if-exists=configs/.env --import tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run clean:dist && concurrently \"npm run build:js\" \"npm run build:types\"",
    "build:js": "tsup src/index.ts --format esm --tsconfig configs/tsconfig.json",
    "build:types": "tsc -p configs/tsconfig.json --emitDeclarationOnly --outDir dist",
    "format": "prettier --config configs/.prettierrc --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripting/**/*.ts\" \"docs/**/*.md\" \"*.md\" \"configs/*.json\" \"configs/*.ts\" \"*.json\"",
    "lint": "eslint --config configs/eslint.config.mjs \"src/**/*.ts\" \"tests/**/*.ts\" \"scripting/**/*.ts\"",
    "lint:fix": "eslint --config configs/eslint.config.mjs \"src/**/*.ts\" \"tests/**/*.ts\" \"scripting/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "test:unit": "vitest run --config configs/vitest.config.ts",
    "test:integration": "vitest run --config configs/vitest.config.ts",
    "test:watch": "vitest --config configs/vitest.config.ts",
    "clean": "concurrently \"npm run clean:dist\" \"npm run clean:modules\"",
    "clean:dist": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "clean:modules": "node -e \"fs.rmSync('node_modules', { recursive: true, force: true })\"",
    "clean:sessions": "node -e \"fs.rmSync('sessions', { recursive: true, force: true })\"",
    "clean:logs": "node -e \"fs.rmSync('logs', { recursive: true, force: true })\"",
    "configure:provider": "tsx scripting/src/configure-provider.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@fastify/http-proxy": "^11.4.4",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
