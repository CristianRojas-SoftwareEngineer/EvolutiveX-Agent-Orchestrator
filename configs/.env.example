# ============================================================
# Smart Code Proxy — Variables de entorno (superficie pública)
# ============================================================
# Copia este archivo a configs/.env y edita solo lo que necesites.
# `npm run dev` carga configs/.env via --env-file-if-exists=configs/.env
# `npm start` (producción) NO carga .env: inyecta variables en el contenedor/sistema.
# Casos excepcionales (cabeceras, gzip, límites internos): docs/advanced-configuration.md
# ============================================================

# --- Servidor ---

# Puerto local del proxy
PORT=8787

# URL objetivo a la que el proxy reenvía las peticiones
UPSTREAM_ORIGIN=https://api.anthropic.com

# Nivel de log Pino (consola y server/logs.jsonl)
# LOG_LEVEL=info

# Tamaño máximo del cuerpo de petición que Fastify acepta en memoria
MAX_REQUEST_BODY=50mb

# Tope único de volcado en disco bajo sessions/ (request, response, sse.txt raw)
# MAX_AUDIT_BYTES=52428800

# TLS hacia el upstream: variable estándar de Node.js (ver README)
# NODE_EXTRA_CA_CERTS=

# --- Thinking Content (opt-in) ---

# true = captura thinking legible en auditoría (implicaciones TOS; ver README)
# PROXY_UNREDACT_THINKING=false

# --- Filtrado de Tools ---

# Omitir = lista por defecto (7 tools internas de Claude Code)
# FILTERED_TOOLS=   # vacío = sin filtrado
# FILTERED_TOOLS=ScheduleWakeup,NotebookEdit
