# ============================================================
# Smart Code Proxy — Variables de entorno
# ============================================================
# Copia este archivo a .env y edita solo lo que necesites.
# El script `npm run dev` carga .env automáticamente via el
# flag nativo de Node.js (--env-file-if-exists). El script
# `npm start` (producción) NO carga .env: inyecta las
# variables en el entorno del sistema o del contenedor.
# ============================================================

# --- Servidor ---

# Puerto local del proxy
PORT=8787

# URL objetivo a la que el proxy reenvía las peticiones
UPSTREAM_ORIGIN=https://api.anthropic.com

# Cabecera Accept-Encoding enviada al upstream.
# Sin definir o vacío = `identity` (evita respuestas gzip; auditoría legible).
# `pass`   = no modificar (reenvía la cabecera original del cliente tal cual).
# `remove` = quitar accept-encoding sin fijar otro valor.
# El evento `listening` en stdout incluye `upstreamAcceptEncoding` (modo efectivo).
UPSTREAM_ACCEPT_ENCODING=identity

# Tamaño máximo del cuerpo de petición que Fastify acepta en memoria
MAX_REQUEST_BODY=50mb

# TLS hacia el upstream: ruta a un PEM con CAs adicionales si hay inspección SSL corporativa.
# Variable estándar de Node.js; ver README.
# NODE_EXTRA_CA_CERTS=

# Tope de buffer de respuesta no-SSE en memoria (afecta auditoría y límite de descompresión en el proxy)
MAX_RESPONSE_BUFFER_BYTES=104857600

# --- Auditoría en disco (sessions/) ---

# 0 = desactivar la escritura de archivos bajo sessions/
AUDIT_ENABLED=1

# Directorio base de sesiones (ruta absoluta o relativa al directorio de trabajo del proceso)
AUDIT_SESSIONS_DIR=sessions

# Límites de volcado en disco
MAX_AUDIT_REQUEST_BODY_BYTES=52428800
MAX_AUDIT_RESPONSE_BODY_BYTES=52428800

# 1 = además de response.sse.jsonl, volcar los bytes crudos del stream SSE en response.sse.txt
AUDIT_SSE_RAW=0

# Tope de bytes para response.sse.txt (solo si AUDIT_SSE_RAW=1).
# Valor por defecto: 52428800 bytes (50MB).
MAX_AUDIT_SSE_RAW_BYTES=52428800

# --- Correlación de sesión ---

# Cabecera primaria (override): gana sobre la secundaria si está presente en la petición.
AUDIT_SESSION_OVERRIDE_HEADER=x-cc-audit-session

# Cabecera secundaria (fallback): la que Claude Code envía por defecto.
AUDIT_SESSION_FALLBACK_HEADER=x-claude-code-session-id

# Si no llega ninguna cabecera útil, usar este valor como nombre de sesión.
DEFAULT_AUDIT_SESSION=

# 1 = añadir sufijo -<hash8> al nombre de carpeta de sesión para evitar colisiones.
AUDIT_SESSION_HASH_SUFFIX=0

# 0 = reenviar al upstream la cabecera que aportó el sessionId.
STRIP_AUDIT_SESSION_HEADER=1


# --- Reconstrucción SSE (Fase 7) ---

# 1 = Reconstruye un JSON completo (response.body.json) al finalizar el stream SSE.
AUDIT_SSE_RESPONSE_BODY=0

# 1 = Solo intenta reconstruir el cuerpo si AUDIT_SSE_RAW está activo y se escribió un .txt válido.
AUDIT_SSE_RESPONSE_BODY_REQUIRE_RAW=1

# 1 = Fuerza el uso de cabeceras Beta de Anthropic durante la reconstrucción interna.
AUDIT_SSE_RESPONSE_BODY_FORCE_BETA=0

# ID del modelo de Anthropic usado para la reconstrucción (SDK Replay).
AUDIT_SSE_REPLAY_MODEL=claude-3-5-sonnet-20241022


# --- Compatibilidad y Logs (Fase 8.5) ---

# 0 = Mostrar información sensible (API Keys, etc) en los logs de la consola durante el desarrollo.
CONSOLE_REDACT=1

# 1 = Imprimir cada línea de datos SSE que llega del upstream directamente a la consola.
LOG_SSE=0

# Límite de bytes para truncar la visualización de cuerpos de petición/respuesta en los logs de Fastify.
MAX_BODY_LOG_BYTES=2048
