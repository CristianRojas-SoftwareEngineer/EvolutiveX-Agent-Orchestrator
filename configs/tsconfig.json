{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "../src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "fastify", "vitest/globals"],
    "declaration": true
  },
  "include": ["../src/**/*"],
  "exclude": ["../dist", "../node_modules"]
}
