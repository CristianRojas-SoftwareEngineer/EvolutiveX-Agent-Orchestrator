{
  "name": "smart-code-proxy",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "help": "node scripts/help.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run clean:dist && concurrently \"npm run build:js\" \"npm run build:types\"",
    "build:js": "tsup src/index.ts --format cjs",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "concurrently \"npm run clean:dist\" \"npm run clean:modules\"",
    "clean:dist": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "clean:modules": "node -e \"fs.rmSync('node_modules', { recursive: true, force: true })\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
