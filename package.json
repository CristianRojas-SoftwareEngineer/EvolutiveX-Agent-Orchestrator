{
  "name": "smart-code-proxy",
  "version": "1.0.0",
  "description": "Proxy de observabilidad de alto rendimiento para interceptar, auditar y analizar tráfico entre clientes IA y la API de Anthropic.",
  "main": "dist/index.js",
  "scripts": {
    "help": "node scripts/help.js",
    "dev": "node --env-file-if-exists=configs/.env node_modules/ts-node/dist/bin.js -P configs/tsconfig.json src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run clean:dist && concurrently \"npm run build:js\" \"npm run build:types\"",
    "build:js": "tsup src/index.ts --format cjs --tsconfig configs/tsconfig.json",
    "build:types": "tsc -p configs/tsconfig.json --emitDeclarationOnly --outDir dist",
    "format": "prettier --config configs/.prettierrc --write \"src/**/*.ts\" \"docs/**/*.md\" \"*.md\" \"configs/*.json\" \"*.json\"",
    "lint": "eslint --config configs/eslint.config.mjs \"src/**/*.ts\"",
    "lint:fix": "eslint --config configs/eslint.config.mjs \"src/**/*.ts\" --fix",
    "test": "npm run lint && npm run build",
    "clean": "concurrently \"npm run clean:dist\" \"npm run clean:modules\"",
    "clean:dist": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "clean:modules": "node -e \"fs.rmSync('node_modules', { recursive: true, force: true })\"",
    "clean:sessions": "node --env-file-if-exists=configs/.env -e \"fs.rmSync(process.env.AUDIT_SESSIONS_DIR || 'sessions', { recursive: true, force: true })\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/http-proxy": "^11.4.4",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "ts-node": {
    "project": "configs/tsconfig.json"
  }
}
